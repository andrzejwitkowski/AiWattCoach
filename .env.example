APP_NAME=AiWattCoach
SERVER_HOST=127.0.0.1
SERVER_PORT=3002
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=aiwattcoach
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=replace-me
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3002/api/auth/google/callback
SESSION_COOKIE_NAME=aiwattcoach_session
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_HOURS=24
SESSION_COOKIE_SECURE=false
ADMIN_EMAILS=
ENABLE_CLIENT_LOG_INGESTION=false
RUST_LOG=info,axum=info,tower_http=info
OTEL_SERVICE_NAME=aiwattcoach-backend
# Use http://alloy:4317 when the app shares a Docker/Coolify network with the logging stack; use localhost when running the collector on the host.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
