#!/usr/bin/env sh

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

case "$staged_files" in
  *".rs"*)
    echo "Rust changes detected; running verify:rust and verify:arch"
    bun run verify:rust && bun run verify:arch
    ;;
  *)
    echo "No staged Rust changes; skipping verify:rust and verify:arch"
    ;;
esac
