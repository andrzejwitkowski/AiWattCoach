# Optional override. Leave unset to use same-origin requests.
VITE_API_BASE_URL=

# Optional frontend hint. Set to true when backend DEV_AUTH_ENABLED is also true.
VITE_DEV_AUTH_ENABLED=false

# Optional Vite dev-server proxy target for /health and /ready.
BACKEND_PROXY_TARGET=http://127.0.0.1:3002
